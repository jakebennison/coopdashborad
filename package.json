{
  "name": "psg-coop-seasons-match-tracker",
  "version": "1.0.0",
  "description": "PSG Co-op Seasons Match Tracker",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:server",
    "build:server": "npx --yes esbuild@0.28.0 server/productionServer.ts --bundle --platform=node --target=node20 --format=esm --packages=external --outfile=dist-server/start.mjs",
    "preview": "vite preview",
    "test": "node --experimental-strip-types --test server/*.test.ts",
    "test:xbox": "node --env-file=.env scripts/xbox-smoke-test.mjs",
    "railway:login": "npx @railway/cli login",
    "railway:link": "npx @railway/cli link",
    "railway:add-postgres": "npx @railway/cli add --database postgres",
    "start": "node dist-server/start.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jakebennison/ai-camera-angle-generator.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jakebennison/ai-camera-angle-generator/issues"
  },
  "homepage": "https://github.com/jakebennison/ai-camera-angle-generator#readme",
  "dependencies": {
    "pg": "^8.16.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
